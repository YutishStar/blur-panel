{
  "rewrites": [
    { "source": "/test", "destination": "/index.html" },
    { "source": "/test/", "destination": "/index.html" },
    { "source": "/test/:path*", "destination": "/:path*" }
  ],
  "headers": [
    {
      "source": "/test",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/test/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
