{
  "rewrites": [
    { "source": "/phone-test", "destination": "/index.html" },
    { "source": "/phone-test/", "destination": "/index.html" },
    { "source": "/asdf1234", "destination": "/analytics.html" },
    { "source": "/asdf1234/", "destination": "/analytics.html" }
  ],
  "headers": [
    {
      "source": "/phone-test",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/phone-test/",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/asdf1234",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/asdf1234/",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
